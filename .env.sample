# Mac Mini Agent Configuration
# Copy to .env and fill in your values

# Claude Code API key (required for job execution)
ANTHROPIC_API_KEY=

# Telegram bot token (required for remote control)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Authorized Telegram user IDs (recommended for security)
# Comma-separated list of user IDs
TELEGRAM_ALLOWED_USERS=

# Listen server URL (default: http://localhost:7600)
# LISTEN_URL=http://localhost:7600
